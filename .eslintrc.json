{
  "env": {
    "browser": true,
    "es2020": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "script"
  },
  "rules": {
    "no-unused-vars": ["warn", { "vars": "all", "args": "none" }],
    "consistent-return": "warn",
    "valid-jsdoc": "off",
    "no-console": ["warn", { "allow": ["warn", "error", "info"] }]
  },
  "globals": {
    "THREE": "readonly",
    "emailjs": "readonly"
  }
}
